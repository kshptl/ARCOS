{
  "ci": {
    "collect": {
      "staticDistDir": "./out",
      "url": ["/", "/explorer.html", "/methodology.html", "/county/54059.html"],
      "numberOfRuns": 3,
      "settings": {
        "chromeFlags": "--no-sandbox --headless=new --disable-dev-shm-usage"
      }
    },
    "assert": {
      "assertMatrix": [
        {
          "matchingUrlPattern": ".*",
          "assertions": {
            "categories:accessibility": ["error", { "minScore": 0.95 }],
            "categories:best-practices": ["error", { "minScore": 0.9 }],
            "categories:seo": ["error", { "minScore": 0.9 }],
            "categories:performance": ["error", { "minScore": 0.75 }],
            "cumulative-layout-shift": ["error", { "maxNumericValue": 0.1 }],
            "color-contrast": ["error", { "minScore": 1 }],
            "errors-in-console": ["warn", { "minScore": 1 }]
          }
        },
        {
          "matchingUrlPattern": "/$",
          "assertions": {
            "largest-contentful-paint": ["error", { "maxNumericValue": 5500 }],
            "total-blocking-time": ["error", { "maxNumericValue": 500 }]
          }
        },
        {
          "matchingUrlPattern": "/explorer\\.html$",
          "assertions": {
            "largest-contentful-paint": ["error", { "maxNumericValue": 7000 }],
            "total-blocking-time": ["error", { "maxNumericValue": 500 }]
          }
        },
        {
          "matchingUrlPattern": "/methodology\\.html$",
          "assertions": {
            "largest-contentful-paint": ["error", { "maxNumericValue": 5500 }],
            "total-blocking-time": ["error", { "maxNumericValue": 500 }]
          }
        },
        {
          "matchingUrlPattern": "/county/",
          "assertions": {
            "largest-contentful-paint": ["error", { "maxNumericValue": 5500 }],
            "total-blocking-time": ["error", { "maxNumericValue": 500 }]
          }
        }
      ]
    },
    "upload": { "target": "temporary-public-storage" }
  }
}
